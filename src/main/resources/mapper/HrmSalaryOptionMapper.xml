<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tianye.hrsystem.modules.salary.mapper.HrmSalaryOptionMapper">
    <select id="querySalaryOptionTemplateList" resultType="com.tianye.hrsystem.modules.salary.entity.HrmSalaryOptionTemplate">
        select a.*, ifnull(b.is_open, 0) as isOpen
        from hrm_salary_option_template a
                 left join hrm_salary_option b on a.code = b.code
    </select>
</mapper>
