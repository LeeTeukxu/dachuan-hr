<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tianye.hrsystem.modules.salary.mapper.HrmSalaryChangeTemplateMapper">
    <select id="queryChangeSalaryOption" resultType="com.tianye.hrsystem.modules.salary.vo.ChangeSalaryOptionVO">
        select code, name
        from hrm_salary_option
        where is_plus=1
        order by code
    </select>
</mapper>
