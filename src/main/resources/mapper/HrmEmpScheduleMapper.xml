<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tianye.hrsystem.mapper.HrmEmpScheduleMapper">
    <select id="getEmpScheduleByParams" parameterType="java.util.HashMap" resultType="com.tianye.hrsystem.entity.po.HrmEmpSchedule">
        select * from hrm_emp_schedule where  emp_id=#{employeeId} and work_date=#{workDate} limit 1
    </select>
</mapper>